# =============================================================================
# AI Financial Intelligence Platform - environment configuration (EXAMPLE)
# Copy this file to `.env` in the repository root and fill in real values.
# NEVER commit the real `.env`. Treat every value here as a secret.
# =============================================================================

# --- Runtime ---------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO

# --- Database (Supabase Postgres) ------------------------------------------
# Async SQLAlchemy + asyncpg connection string for the Supabase project.
# Format: postgresql+asyncpg://postgres:<PASSWORD>@db.<REF>.supabase.co:5432/postgres
# (Or the pooler host on port 6543.) Get the password from the Supabase
# dashboard -> Project Settings -> Database.
DATABASE_URL=<<ASK_SUPABASE_DATABASE_URL>>

# --- Hugging Face / Kronos forecasting -------------------------------------
# Kronos models are PUBLIC (MIT), so HF_TOKEN is optional. Provide it only if
# you hit rate limits or use a private mirror.
HF_TOKEN=
KRONOS_MODEL_ID=NeoQuasar/Kronos-small
KRONOS_TOKENIZER_ID=NeoQuasar/Kronos-Tokenizer-base
KRONOS_MAX_CONTEXT=512
KRONOS_DEVICE=cpu

# --- Data ingestion / scheduler --------------------------------------------
DEFAULT_HISTORY_DAYS=1095
ENABLE_SCHEDULER=true
DAILY_INGEST_HOUR=13          # UTC hour for the daily fetch (~after IST close)
DAILY_INGEST_MINUTE=0

# --- Phase 2+ (NOT used in Phase 1; placeholders only) ---------------------
# The research document leaked live keys - rotate those and put fresh values
# here ONLY when the agent/LLM phase begins.
OPENAI_API_KEY=<<ASK_OPENAI_API_KEY>>
ANTHROPIC_API_KEY=<<ASK_ANTHROPIC_API_KEY>>
