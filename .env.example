# =============================================================================
# AI Financial Intelligence Platform - environment configuration (EXAMPLE)
# Copy this file to `.env` in the repository root and fill in real values.
# NEVER commit the real `.env`. Treat every value here as a secret.
# =============================================================================

# --- Runtime ---------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO

# --- API security (Phase 2.5) -----------------------------------------------
# When API_KEY is set, every endpoint except /live, /health and docs requires
# the X-API-Key header. Leave empty ONLY for local development.
API_KEY=<<GENERATE_A_LONG_RANDOM_STRING>>
RATE_LIMIT_PER_MINUTE=120
# Comma-separated allowed origins for the (Phase 3) frontend; empty = no CORS.
CORS_ORIGINS=
# Include raw internal error text in API responses (development only).
EXPOSE_ERROR_DETAILS=false

# --- Supabase Auth (Phase 4 user authentication) -----------------------------
# Enables Bearer-JWT user auth. The anon key is safe to share (public client
# key). If SUPABASE_JWT_SECRET is set, tokens verify locally (fast path);
# otherwise the backend validates tokens against /auth/v1/user (cached).
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_ANON_KEY=<<ASK_SUPABASE_ANON_KEY>>
SUPABASE_JWT_SECRET=

# --- Database (Supabase Postgres) ------------------------------------------
# Async SQLAlchemy + asyncpg connection string for the Supabase project.
# Direct:  postgresql+asyncpg://postgres:<PASSWORD>@db.<REF>.supabase.co:5432/postgres
# Pooler:  postgresql+asyncpg://postgres.<REF>:<PASSWORD>@<region>.pooler.supabase.com:6543/postgres
#          (pooler URLs are auto-detected and the asyncpg statement cache is
#           disabled for PgBouncer compatibility; override with
#           DB_STATEMENT_CACHE_SIZE if needed)
# PRODUCTION: connect the app as a least-privilege role (DML on app tables
# only), NOT as postgres; keep a separate elevated role for migrations.
DATABASE_URL=<<ASK_SUPABASE_DATABASE_URL>>
#DB_STATEMENT_CACHE_SIZE=

# --- Agent execution hardening (Phase 2.5) -----------------------------------
MAX_CONCURRENT_AGENT_RUNS=2
AGENT_RUN_TIMEOUT_SECONDS=600
AGENT_RUN_STALE_MINUTES=30
MEMORY_TTL_DAYS=90

# --- Hugging Face / Kronos forecasting -------------------------------------
# Kronos models are PUBLIC (MIT), so HF_TOKEN is optional for local mode.
# In REMOTE mode against a private inference Space, HF_TOKEN must be a
# fine-grained token with read access to that Space.
HF_TOKEN=
KRONOS_MODEL_ID=NeoQuasar/Kronos-small
KRONOS_TOKENIZER_ID=NeoQuasar/Kronos-Tokenizer-base
KRONOS_MAX_CONTEXT=512
KRONOS_DEVICE=cpu

# --- Remote inference (Phase 4.5: Hugging Face Space) ------------------------
# local  = run Kronos/MiniLM in-process (dev default; needs `pip install
#          -e .[dev,local-ml]`).
# remote = call the inference Space (production: the Render image has no torch).
KRONOS_MODE=local
EMBEDDINGS_MODE=local
# e.g. https://eklavya73-ai-inference-service.hf.space
INFERENCE_SPACE_URL=
# Optional shared secret (X-API-Key) if the Space is public; private Spaces
# authenticate with HF_TOKEN instead.
INFERENCE_SPACE_API_KEY=
#INFERENCE_CONNECT_TIMEOUT_SECONDS=10
#INFERENCE_READ_TIMEOUT_SECONDS=120
#INFERENCE_MAX_RETRIES=2
#INFERENCE_RETRY_BACKOFF_SECONDS=1.5
#INFERENCE_WAKE_MAX_WAIT_SECONDS=180

# --- Data ingestion / scheduler --------------------------------------------
DEFAULT_HISTORY_DAYS=1095
ENABLE_SCHEDULER=true
DAILY_INGEST_HOUR=13          # UTC hour for the daily fetch (~after IST close)
DAILY_INGEST_MINUTE=0

# --- LLM providers (Phase 2 agents) -----------------------------------------
# Gemini is primary; OpenAI is the automatic fallback. 'fake' is for tests.
LLM_PROVIDER=gemini
LLM_FALLBACK_PROVIDER=openai
GOOGLE_AI_STUDIO_API_KEY=<<ASK_GOOGLE_AI_STUDIO_API_KEY>>
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=<<ASK_OPENAI_API_KEY>>
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=<<ASK_ANTHROPIC_API_KEY>>

# --- News / sentiment (Phase 2) ----------------------------------------------
NEWSAPI_KEY=<<ASK_NEWSAPI_KEY>>
NEWS_LOOKBACK_DAYS=7
NEWS_MAX_HEADLINES=12

# --- Data providers (Phase 6; all optional, degrade gracefully when keyless) -
# Finnhub: company news + quotes (free 60/min). Alpha Vantage: fundamentals +
# quotes (free 25/day hard cap; weak NSE coverage - supplemental only).
FINNHUB_API_KEY=<<ASK_FINNHUB_KEY>>
ALPHA_VANTAGE_API_KEY=<<ASK_ALPHA_VANTAGE_KEY>>
ALPHA_VANTAGE_DAILY_CAP=20
PROVIDER_PRIORITY=yfinance,finnhub,alpha_vantage,newsapi

# --- Agents (Phase 2) ---------------------------------------------------------
AGENTS_DEBATE_ROUNDS=1
MAX_POSITION_PCT=10
RISK_MAX_DRAWDOWN_VETO_PCT=40
ENABLE_AGENT_MEMORY=true

# --- Paper trading / research / evaluation (Phase 5) -------------------------
SIM_STARTING_CASH=1000000
FUNDAMENTALS_TTL_HOURS=24
ENABLE_NEWS_INGEST=true
NEWS_RAG_TOP_K=5
NEWS_RETENTION_DAYS=180
# Phase 6 market expansion (quota guards at ~100 instruments)
NEWS_INGEST_DAILY_CAP=60
INGEST_PAUSE_SECONDS=0.3
# LLM cost estimation (per 1M tokens, USD) used by /evaluation/summary.
LLM_COST_INPUT_PER_1M=0.30
LLM_COST_OUTPUT_PER_1M=2.50
