# Frontend environment (Next.js). Copy to .env.local for local dev; set the
# same keys in the Vercel project for production. NEVER commit real values.

# --- Supabase (public client keys; safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>

# --- Backend proxy (server-side only; never exposed to the browser) ---
# Production: the Render backend URL. Local dev: http://127.0.0.1:8000.
BACKEND_URL=http://127.0.0.1:8000
# Local-dev fallback auth for the proxy when there is no user session.
# LEAVE EMPTY in production (users authenticate with their own Supabase session).
BACKEND_API_KEY=

# --- Guest access (Phase 4.6; server-side only) ---
# The shared, pre-provisioned guest Supabase account. When both are set, the
# login page shows "Continue as Guest". The guest is a normal 'user' role.
GUEST_EMAIL=guest@finintel.app
GUEST_PASSWORD=<guest-account-password>
